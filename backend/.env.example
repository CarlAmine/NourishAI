APP_NAME=NourishAI
APP_VERSION=1.0.0
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
LOG_LEVEL=INFO
STRICT_STARTUP=false

DATA_DIR=data
ARTIFACTS_DIR=artifacts
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
RETRIEVAL_CANDIDATES=50
HYBRID_ALPHA=0.65

MODELS_DIR=models
GDRIVE_RAW_RECIPES_ID=1lE6zl-9dJKUnNu6CDuBvHPpGodKrGnoX
IMAGE_MODEL_URL=https://github.com/CarlAmine/EECE-490/releases/download/v1.0/490Image.pkl
IMAGE_MODEL_EXPECTED_SIZE_MB=687
FAISS_INDEX_PATH=models/faiss.index
RECIPES_PKL_PATH=models/recipe.pkl
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=800
OPENAI_TIMEOUT_SEC=20

# Legacy Qdrant ingestion (optional, not used by FAISS retrieval)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=nourishai_chunks
LEXICAL_INDEX_PATH=artifacts/lexical_index.pkl
CHUNK_STORE_PATH=artifacts/chunks.jsonl
INGESTION_MANIFEST_PATH=artifacts/ingestion_manifest.json
